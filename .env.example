# Resend API key (https://resend.com/api-keys)
# Without this, the waitlist endpoint logs to console and returns success.
RESEND_API_KEY=

# Email address that receives waitlist signup notifications.
WAITLIST_TO_EMAIL=hello@christnote.app

# From address Resend will send notification emails as.
# Must be a verified domain on Resend.
WAITLIST_FROM_EMAIL=waitlist@christnote.app
