---
interface Props {
  name: 'mic' | 'cloud-upload' | 'sparkle' | 'plus' | 'arrow-right' | 'cross';
  size?: number;
  class?: string;
}
const { name, size = 24, class: className } = Astro.props;
---
<svg width={size} height={size} aria-hidden="true" class={className}>
  <use href={`#icon-${name}`} />
</svg>
