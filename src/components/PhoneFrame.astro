---
interface Props {
  src: string;
  alt: string;
  width?: number;
}
const { src, alt, width = 280 } = Astro.props;
---
<div class="phone-bezel" style={`width: ${width}px;`}>
  <div class="phone-screen">
    <img src={src} alt={alt} loading="lazy" decoding="async" />
  </div>
</div>

<style>
.phone-bezel {
  aspect-ratio: 9 / 19.5;
  background: var(--ink-900);
  border-radius: 44px;
  padding: 8px;
  box-shadow: 0 30px 60px rgba(42,31,24,0.18), 0 8px 20px rgba(42,31,24,0.10);
  position: relative;
}
.phone-bezel::before {
  content: "";
  position: absolute;
  inset: 1px;
  border-radius: 43px;
  background: linear-gradient(180deg, var(--brass-300) 0%, transparent 14%);
  opacity: 0.35;
  pointer-events: none;
}
.phone-screen {
  width: 100%;
  height: 100%;
  border-radius: 36px;
  overflow: hidden;
  background: var(--parchment-50);
  position: relative;
}
.phone-screen img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
}
</style>
