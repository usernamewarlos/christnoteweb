---
import Icon from './Icon.astro';

interface Props {
  question: string;
}
const { question } = Astro.props;
---
<details class="faq-item">
  <summary class="faq-trigger">
    <span>{question}</span>
    <span class="faq-icon"><Icon name="plus" size={18} /></span>
  </summary>
  <div class="faq-answer"><slot /></div>
</details>

<style>
.faq-item {
  border-top: 1px solid var(--color-divider);
}
.faq-item:last-child {
  border-bottom: 1px solid var(--color-divider);
}
.faq-trigger {
  list-style: none;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--s-6);
  padding: var(--s-6) 0;
  font-family: var(--font-ui);
  font-size: 17px;
  font-weight: 600;
  color: var(--ink-900);
}
.faq-trigger::-webkit-details-marker { display: none; }
.faq-trigger:hover { color: var(--brass-600); }
.faq-icon {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brass-500);
  transition: transform var(--dur-base) var(--ease-out);
}
.faq-item[open] .faq-icon { transform: rotate(45deg); }
.faq-answer {
  padding: 0 0 var(--s-6);
  font-family: var(--font-ui);
  font-size: 16px;
  color: var(--ink-600);
  line-height: var(--lh-body);
  max-width: 64ch;
}
</style>
