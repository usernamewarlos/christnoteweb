---
import Icon from './Icon.astro';

interface Props {
  icon: 'mic' | 'cloud-upload' | 'sparkle' | 'plus' | 'arrow-right' | 'cross';
  title: string;
}
const { icon, title } = Astro.props;
---
<div class="feature-col">
  <div class="feature-icon">
    <Icon name={icon} size={28} />
  </div>
  <h3 class="feature-title">{title}</h3>
  <p class="feature-body"><slot /></p>
</div>

<style>
.feature-col {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--s-3);
}
.feature-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--brass-100);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--brass-600);
  margin-bottom: var(--s-2);
}
.feature-title {
  font-family: var(--font-display);
  font-size: 24px;
  font-weight: 600;
  color: var(--ink-900);
}
.feature-body {
  font-family: var(--font-ui);
  font-size: 15px;
  color: var(--ink-600);
  max-width: 30ch;
  line-height: 1.55;
}
</style>
