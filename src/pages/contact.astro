---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/prose.css';

export const prerender = true;
---
<Layout
  title="Contact — Christ Note"
  description="Get in touch with Christ Note — questions, feedback, press."
>
  <Nav />

  <main class="prose-page">
    <div class="container">
      <header class="prose-head">
        <a class="back-link" href="/">← Back home</a>
        <span class="eyebrow">Contact</span>
        <h1>Get in touch</h1>
      </header>

      <article class="prose">
        <p class="lede">
          Questions, feedback, press, or something we missed — write to us. We read every message and reply from a real person.
        </p>

        <section class="contact-card">
          <span class="contact-label">Email</span>
          <a class="contact-email" href="mailto:support@christnote.app">support@christnote.app</a>
          <p class="contact-note">Most replies land within two business days.</p>
        </section>

        <p class="contact-entity">
          <strong>SixFortyLabs LLC</strong><br />
          Texas, USA
        </p>
      </article>
    </div>
  </main>

  <Footer />
</Layout>

<style>
.contact-card {
  margin: var(--s-10) 0 var(--s-8);
  padding: var(--s-8) var(--s-8);
  border-radius: 16px;
  background: var(--parchment-100);
  border: 1px solid var(--divider, rgba(0,0,0,0.08));
  text-align: center;
}
.contact-label {
  display: block;
  font-family: var(--font-ui);
  font-size: 12px;
  font-weight: 600;
  letter-spacing: var(--tracking-eyebrow);
  text-transform: uppercase;
  color: var(--brass-600);
  margin-bottom: var(--s-3);
}
.contact-email {
  display: inline-block;
  font-family: var(--font-display);
  font-size: clamp(22px, 2.2vw, 28px);
  font-weight: 500;
  color: var(--ink-900);
  text-decoration: none;
  border-bottom: 1px solid var(--brass-400);
  padding-bottom: 4px;
  transition: color var(--dur-fast) var(--ease-out);
}
.contact-email:hover { color: var(--brass-600); }
.contact-note {
  font-family: var(--font-ui);
  font-size: 13px;
  color: var(--ink-500);
  margin: var(--s-4) 0 0;
}
.contact-entity {
  font-family: var(--font-ui);
  font-size: 14px;
  color: var(--ink-600);
  line-height: 1.6;
  margin-top: var(--s-10);
}
</style>
