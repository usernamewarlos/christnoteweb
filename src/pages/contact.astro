---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/prose.css';

export const prerender = true;
---
<Layout
  title="Contact — Christ Note"
  description="Get in touch with Christ Note customer support."
>
  <Nav />

  <main class="contact-page">
    <div class="container">
      <a class="back-link" href="/">← Back home</a>

      <h1 class="contact-title">Customer support</h1>

      <p class="contact-body">
        At Christ Note, we're here to support you every step of the way. If you have any questions, concerns, or need assistance with the app, we're just an email away.
      </p>

      <p class="contact-email-line">
        Email us at <a href="mailto:support@christnote.app">support@christnote.app</a>
      </p>

      <p class="contact-response">
        Our customer support team will do their best to get back to you within 48 hours.
      </p>
    </div>
  </main>

  <Footer />
</Layout>

<style>
.contact-page {
  padding: var(--s-16) 0 var(--s-20);
  background: var(--parchment-50);
  text-align: center;
}
.back-link {
  display: inline-block;
  font-family: var(--font-ui);
  font-size: 14px;
  color: var(--ink-500);
  text-decoration: none;
  margin-bottom: var(--s-10);
}
.back-link:hover { color: var(--brass-600); }
.contact-title {
  font-family: var(--font-display);
  font-size: clamp(32px, 4vw, 44px);
  font-weight: 500;
  color: var(--ink-900);
  letter-spacing: var(--tracking-tight);
  margin: 0 0 var(--s-8);
}
.contact-body {
  font-family: "Cormorant Garamond", Georgia, serif;
  font-style: italic;
  font-size: clamp(18px, 1.6vw, 21px);
  color: var(--ink-700);
  line-height: 1.55;
  max-width: 52ch;
  margin: 0 auto var(--s-10);
}
.contact-email-line {
  font-family: var(--font-ui);
  font-size: clamp(16px, 1.4vw, 18px);
  color: var(--ink-800);
  margin: 0 0 var(--s-4);
}
.contact-email-line a {
  color: var(--brass-600);
  font-weight: 600;
  text-decoration: none;
  border-bottom: 1px solid var(--brass-400);
  padding-bottom: 2px;
}
.contact-email-line a:hover {
  color: var(--brass-700);
}
.contact-response {
  font-family: var(--font-ui);
  font-size: 14px;
  color: var(--ink-500);
  max-width: 48ch;
  margin: 0 auto;
}
</style>
